{
  "name": "AudioForge – Pro Audio Editor",
  "short_name": "AudioForge",
  "description": "Professional audio and song editor. Vocal removal, EQ, effects, trim, fade and export.",
  "start_url": "./index.html",
  "display": "standalone",
  "orientation": "landscape-primary",
  "background_color": "#020509",
  "theme_color": "#040810",
  "categories": ["music", "utilities", "productivity"],
  "lang": "en",
  "icons": [
    { "src": "icons/icon-72.png",  "sizes": "72x72",   "type": "image/png", "purpose": "maskable any" },
    { "src": "icons/icon-96.png",  "sizes": "96x96",   "type": "image/png", "purpose": "maskable any" },
    { "src": "icons/icon-128.png", "sizes": "128x128", "type": "image/png", "purpose": "maskable any" },
    { "src": "icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable any" },
    { "src": "icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable any" }
  ],
  "screenshots": [],
  "shortcuts": [
    {
      "name": "Open AudioForge",
      "short_name": "Editor",
      "url": "./index.html",
      "icons": [{ "src": "icons/icon-96.png", "sizes": "96x96" }]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "handle_links": "preferred",
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "audio/mpeg": [".mp3"],
        "audio/wav": [".wav"],
        "audio/ogg": [".ogg"],
        "audio/flac": [".flac"],
        "audio/aac": [".aac", ".m4a"],
        "audio/webm": [".weba"]
      }
    }
  ]
}
